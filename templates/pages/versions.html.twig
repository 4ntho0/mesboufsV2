{% extends 'base.html.twig' %}

{% block title %}Versions{% endblock %}

{% block body %}

    <h1 class="mb-4">Évolution du site</h1>

    <div class="timeline">

        {% for v in versions %}
            <div class="card mb-4 shadow-soft">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h4 class="mb-0">
                            Version {{ v.version }} : {{ v.titre }}
                        </h4>
                    </div>

                    <small class="text-muted">
                        {{ v.date ? v.date|date('d/m/Y') : '-' }}
                    </small>

                    <hr>

                    <p style="white-space: pre-line;">
                        {{ v.description }}
                    </p>

                </div>
            </div>
        {% else %}
            <p>Aucune version pour le moment.</p>
        {% endfor %}

    </div>

{% endblock %}