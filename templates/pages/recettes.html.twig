{% extends 'base.html.twig' %}

{% block title %}Liste des recettes{% endblock %}

{% block body %}

<h1 class="mb-4">Toutes les recettes</h1>

<!-- ================= FILTRES ================= -->
<form method="GET" class="mb-4 p-3 bg-white shadow-sm rounded">

    <h5>🔎 Filtrer par catégories</h5>

    <div class="d-flex flex-wrap gap-2 mb-3">

        {% for cat in categories %}
            <label class="form-check me-3">
                <input class="form-check-input"
                       type="checkbox"
                       name="categories[]"
                       value="{{ cat.id }}"
                       {% if cat.id in selectedCategories %}checked{% endif %}>
                <span class="form-check-label">
                    {{ cat.nom }}
                </span>
            </label>
        {% endfor %}

    </div>

    <input type="hidden" name="sort" value="{{ sort }}">
    <input type="hidden" name="direction" value="{{ direction }}">

    <button class="btn btn-primary btn-sm">
        Appliquer
    </button>

</form>

<!-- ================= TABLE ================= -->
<div class="table-responsive bg-white shadow-sm rounded">

<table class="table table-hover mb-0">

    <thead class="table-dark">

        {% set newDirection = direction == 'ASC' ? 'DESC' : 'ASC' %}

        <tr>
            <th>
                <a class="text-white text-decoration-none"
                   href="{{ path('page_recettes', {
                        sort: 'nom',
                        direction: newDirection,
                        categories: selectedCategories
                   }) }}">
                    Nom
                </a>
            </th>

            <th>Catégories</th>

            <th>
                <a class="text-white text-decoration-none"
                   href="{{ path('page_recettes', {
                        sort: 'duree',
                        direction: newDirection,
                        categories: selectedCategories
                   }) }}">
                    Durée
                </a>
            </th>

            <th>
                <a class="text-white text-decoration-none"
                   href="{{ path('page_recettes', {
                        sort: 'note',
                        direction: newDirection,
                        categories: selectedCategories
                   }) }}">
                    Note
                </a>
            </th>
        </tr>

    </thead>

    <tbody>

        {% for recette in recettes %}

            <tr onclick="window.location='{{ path('page_recette', {id: recette.id}) }}'"
                style="cursor:pointer;">

                <td class="fw-semibold">
                    {{ recette.nom }}
                </td>

                <td>
                    {% for cat in recette.categories %}
                        <span class="badge bg-secondary me-1">
                            {{ cat.nom }}
                        </span>
                    {% endfor %}
                </td>

                <td>
                    {{ recette.duree }} min
                </td>

                <td>
                    {% if recette.note %}
                        {{ recette.note.total }}/40
                    {% else %}
                        <span class="text-muted">-</span>
                    {% endif %}
                </td>

            </tr>

        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted py-4">
                    Aucune recette trouvée
                </td>
            </tr>
        {% endfor %}

    </tbody>

</table>

</div>

{% endblock %}