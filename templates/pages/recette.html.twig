{% extends 'base.html.twig' %}


{% block body %}

    <div class="card mb-4 shadow-sm">

        <div class="row align-items-center">

            <!-- LEFT -->
            <div class="col-md-8">

                <h1 class="mb-2">{{ recette.nom }}</h1>

                <div class="text-muted small mb-2">
                    créé le : {{ recette.date ? recette.date|date('d/m/Y') : '-' }}
                </div>

                <div class="text-muted small mb-3">
                    Temps de préparation : {{ recette.duree ?? '-' }} min
                </div>

                <div>
                    {% for cat in recette.categories %}
                        <span class="badge bg-secondary me-1">
                            {{ cat.nom }}
                        </span>
                    {% else %}
                        <span class="text-muted">Aucune catégorie</span>
                    {% endfor %}
                </div>

            </div>

            <!-- RIGHT (IMAGE) -->
            <div class="col-md-4 text-end">

                <div style="width: 100%; max-width: 200px; height: 160px; margin-left: auto;">

                    {% if recette.image %}
                        <img src="{{ asset('uploads/recettes/' ~ recette.image.filename) }}"
                             alt="{{ recette.nom }}"
                             style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;">
                    
                        
                    {% endif %}

                </div>

            </div>

        </div>

    </div>


    <!-- ================= INGREDIENTS ================= -->
    <div class="card mb-4 shadow-sm">

        <div class="card-body">

            <h5 class="card-title">Ingrédients</h5>

            {% if recette.ingredients|length > 0 %}

                <ul class="list-group list-group-flush">

                    {% for ing in recette.ingredients %}
                        <li class="list-group-item">
                            <strong>{{ ing.quantite }}</strong>
                            {{ ing.unitee ? ing.unitee.nom : '' }}
                            -
                            {{ ing.produit.nom }}
                        </li>
                    {% endfor %}

                </ul>

            {% else %}
                <p class="text-muted mb-0">Aucun ingrédient</p>
            {% endif %}

        </div>

    </div>

    <!-- ================= INSTRUCTIONS ================= -->
    <div class="card mb-4 shadow-sm">

        <div class="card-body">

            <h5 class="card-title">Instructions</h5>

            <p style="white-space: pre-line;">{{ recette.instruction }}</p>

        </div>

    </div>

    <!-- ================= NOTE ================= -->
    <div class="card shadow-sm">

        <div class="card-body">

            <h5 class="card-title">Note de la recette</h5>

            {% if recette.note %}

                <div class="row text-center">

                    <div class="col">
                        <strong>Aspect Visuel</strong><br>
                        {{ recette.note.noteAspect }}/10
                    </div>

                    <div class="col">
                        <strong>Odeur</strong><br>
                        {{ recette.note.noteOdeur }}/10
                    </div>

                    <div class="col">
                        <strong>Goût</strong><br>
                        {{ recette.note.noteGout }}/10
                    </div>

                    <div class="col">
                        <strong>Texture</strong><br>
                        {{ recette.note.noteTexture }}/10
                    </div>

                </div>

                <hr>

                <div class="text-center fs-4">
                    Total : {{ recette.note.total }}/40
                </div>

            {% else %}
                <p class="text-muted">Aucune note pour cette recette</p>
            {% endif %}

        </div>

    </div>

{% endblock %}