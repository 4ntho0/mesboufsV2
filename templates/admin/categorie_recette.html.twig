{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}

<h1>Catégories de recettes</h1>

<h2>Ajouter une catégorie</h2>

<form method="post" action="{{ path('categorie_recette_add') }}">
    <input type="text" name="nom" placeholder="Nom de la catégorie" required>
    <button type="submit">Ajouter</button>
</form>

<hr>

<h2>Liste</h2>

<ul>
    {% for categorie in categories %}
        <li>
            {{ categorie.nom }}

            <form method="post" action="{{ path('categorie_recette_delete', {id: categorie.id}) }}" style="display:inline;">
                <button onclick="return confirm('Supprimer ?')">❌</button>
            </form>
        </li>
    {% else %}
        <li>Aucune catégorie</li>
    {% endfor %}
</ul>

{% endblock %}