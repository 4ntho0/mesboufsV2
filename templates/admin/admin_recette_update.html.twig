{% extends 'base.admin.html.twig' %}

{% block title %}Modifier recette{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1>✏️ Modifier la recette</h1>

        <a href="{{ path('admin.recettes') }}" class="btn btn-outline-secondary">
            ← Retour
        </a>

    </div>

    <div class="admin-card">

        <form method="POST" action="{{ path('admin.recette_update', {id: recette.id}) }}">

            {# NOM #}
            <div class="mb-3">
                <label class="form-label">Nom</label>
                <input type="text"
                       name="nom"
                       value="{{ recette.nom }}"
                       class="form-control"
                       required>
            </div>

            {# DURÉE #}
            <div class="mb-3">
                <label class="form-label">Durée (min)</label>
                <input type="number"
                       name="duree"
                       value="{{ recette.duree }}"
                       class="form-control">
            </div>

            {# INSTRUCTIONS #}
            <div class="mb-3">
                <label class="form-label">Instructions</label>
                <textarea name="instruction"
                          class="form-control"
                          rows="5">{{ recette.instruction }}</textarea>
            </div>

            {# CATÉGORIES #}
            <div class="mb-3">
                <label class="form-label">Catégories</label>

                <select name="categories[]"
                        class="form-control"
                        multiple>

                    {% for cat in categories %}
                        <option value="{{ cat.id }}"
                                {% if cat in recette.categories %}selected{% endif %}>
                            {{ cat.nom }}
                        </option>
                    {% endfor %}

                </select>

                <small class="text-muted">
                    Maintenir CTRL (ou CMD) pour sélectionner plusieurs catégories
                </small>

            </div>

            {# ACTION #}
            <div class="text-end">

                <button type="submit" class="btn btn-primary">
                    💾 Enregistrer les modifications
                </button>

            </div>

        </form>

    </div>

{% endblock %}