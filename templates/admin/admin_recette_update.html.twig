{% extends 'base.admin.html.twig' %}

{% block title %}Modifier recette{% endblock %}

{% block body %}

<h1>Modifier la recette</h1>

<form method="POST" action="{{ path('recette_update', {id: recette.id}) }}">

    <div>
        <label>Nom</label>
        <input type="text" name="nom" value="{{ recette.nom }}" required>
    </div>

    <div>
        <label>Durée (min)</label>
        <input type="number" name="duree" value="{{ recette.duree }}">
    </div>

    <div>
        <label>Instructions</label>
        <textarea name="instruction">{{ recette.instruction }}</textarea>
    </div>

    <div>
        <label>Catégories</label>
        <select name="categories[]" multiple>
            {% for cat in categories %}
                <option value="{{ cat.id }}"
                    {% if cat in recette.categories %}selected{% endif %}>
                    {{ cat.nom }}
                </option>
            {% endfor %}
        </select>
    </div>

    <button type="submit">Enregistrer les modifications</button>

</form>

<br>

<a href="{{ path('recettes') }}">← Retour</a>

{% endblock %}