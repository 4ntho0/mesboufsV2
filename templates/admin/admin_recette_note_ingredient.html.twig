{% extends 'base.admin.html.twig' %}

{% block title %}Gestion recette{% endblock %}

{% block body %}

    <h1>{{ recette.nom }}</h1>

    <hr>

    {# ================= INGREDIENTS ================= #}

    <h2>Ajouter un ingrédient</h2>

    <form method="POST" action="{{ path('recette_add_ingredient', {id: recette.id}) }}">

        <div>
            <label>Catégorie</label>
            <select id="categorie-select">
                <option value="">-- Choisir --</option>
                {% for c in categoriesProduits %}
                    <option value="{{ c.id }}">{{ c.nom }}</option>
                {% endfor %}
            </select>

        </div>

        <div>
            <select name="produit" id="produit-select">
                <option value="">-- Choisir une catégorie --</option>
            </select>
        </div>

        <div>
            <label>Quantité</label>
            <input type="number" step="0.01" name="quantite" required>
        </div>

        <div>
            <label>Unité</label>
            <select name="unitee">
                {% for u in unitees %}
                    <option value="{{ u.id }}">{{ u.nom }}</option>
                {% endfor %}
            </select>
        </div>

        <button type="submit">Ajouter</button>
    </form>

    <hr>

    <h3>Ingrédients actuels</h3>

    <ul>
        {% for ing in recette.ingredients %}
            <li>
                {{ ing.quantite }} {{ ing.unitee.nom }} - {{ ing.produit.nom }}

                <form method="POST"
                      action="{{ path('recette_delete_ingredient', {id: ing.id}) }}"
                      style="display:inline;">

                    <button type="submit">
                        ❌
                    </button>
                </form>
            </li>
        {% else %}
            <li>Aucun ingrédient</li>
            {% endfor %}
    </ul>

    <hr>

    {# ================= NOTES ================= #}

    <h2>Notes de la recette</h2>

    <form method="POST" action="{{ path('recette_save_note', {id: recette.id}) }}">

        <div>
            <label>Aspect</label>
            <input type="number" name="noteAspect" min="0" max="10" value="{{ recette.note ? recette.note.noteAspect : '' }}">
        </div>

        <div>
            <label>Odeur</label>
            <input type="number" name="noteOdeur" min="0" max="10" value="{{ recette.note ? recette.note.noteOdeur : '' }}">
        </div>

        <div>
            <label>Goût</label>
            <input type="number" name="noteGout" min="0" max="10" value="{{ recette.note ? recette.note.noteGout : '' }}">
        </div>

        <div>
            <label>Texture</label>
            <input type="number" name="noteTexture" min="0" max="10" value="{{ recette.note ? recette.note.noteTexture : '' }}">
        </div>

        <button type="submit">
            Enregistrer tout
        </button>
    </form>

    <hr>

    <a href="{{ path('recettes') }}">← Retour</a>

{% endblock %}
{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const categorieSelect = document.getElementById('categorie-select');
            const produitSelect = document.getElementById('produit-select');

            categorieSelect.addEventListener('change', function () {

                const categorieId = this.value;

                if (!categorieId) {
                    produitSelect.innerHTML = '<option>Choisir une catégorie</option>';
                    return;
                }

                const urlTemplate = "{{ path('produits_by_categorie', {'id': 'ID'}) }}";
                const url = urlTemplate.replace('ID', categorieId);

                produitSelect.innerHTML = '<option>Chargement...</option>';

                fetch(url)
                        .then(response => response.json())
                        .then(data => {

                            console.log("DATA:", data); // 🔥 debug

                            produitSelect.innerHTML = '';

                            data.forEach(produit => {
                                const option = document.createElement('option');
                                option.value = produit.id;
                                option.textContent = produit.nom;
                                produitSelect.appendChild(option);
                            });

                            if (data.length === 0) {
                                produitSelect.innerHTML = '<option>Aucun produit</option>';
                            }
                        })
                        .catch(error => {
                            console.error("Erreur:", error);
                        });

            });

        });
    </script>

{% endblock %}