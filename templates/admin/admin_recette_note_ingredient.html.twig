{% extends 'base.admin.html.twig' %}

{% block title %}Gestion recette{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1>🍽 {{ recette.nom }}</h1>

    <a href="{{ path('admin.recettes') }}" class="btn btn-outline-secondary">
        ← Retour
    </a>

</div>

{# ================= INGREDIENTS ================= #}
<div class="admin-card mb-4">

    <h3>➕ Ajouter un ingrédient</h3>

    <form method="POST" action="{{ path('admin.recette_add_ingredient', {id: recette.id}) }}">

        <div class="mb-3">
            <label class="form-label">Catégorie</label>

            <select id="categorie-select" class="form-control">
                <option value="">-- Choisir une catégorie --</option>

                {% for c in categoriesProduits %}
                    <option value="{{ c.id }}">{{ c.nom }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Produit</label>

            <select name="produit"
                    id="produit-select"
                    class="form-control"
                    required>
                <option value="">-- Choisir une catégorie d'abord --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Quantité</label>
            <input type="number"
                   step="0.01"
                   name="quantite"
                   class="form-control"
                   required>
        </div>

        <div class="mb-3">
            <label class="form-label">Unité</label>

            <select name="unitee" class="form-control" required>
                {% for u in unitees %}
                    <option value="{{ u.id }}">{{ u.nom }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary">
                ➕ Ajouter
            </button>
        </div>

    </form>

</div>

{# ================= LISTE INGREDIENTS ================= #}
<div class="admin-card mb-4">

    <h3>📦 Ingrédients actuels</h3>

    <ul class="list-group">

        {% for ing in recette.ingredients %}

            <li class="list-group-item d-flex justify-content-between align-items-center">

                <span>
                    {{ ing.quantite }} {{ ing.unitee.nom }} - <strong>{{ ing.produit.nom }}</strong>
                </span>

                <form method="POST"
                      action="{{ path('admin.recette_delete_ingredient', {id: ing.id}) }}"
                      onsubmit="return confirm('Supprimer cet ingrédient ?');">

                    <button class="btn btn-sm btn-outline-danger">
                        ❌
                    </button>

                </form>

            </li>

        {% else %}

            <li class="list-group-item text-muted">
                Aucun ingrédient
            </li>

        {% endfor %}

    </ul>

</div>

{# ================= NOTES ================= #}
<div class="admin-card mb-4">

    <h3>⭐ Notes de la recette</h3>

    <form method="POST" action="{{ path('admin.recette_save_note', {id: recette.id}) }}">

        <div class="row">

            <div class="col-md-3 mb-3">
                <label>Aspect</label>
                <input type="number" name="noteAspect"
                       min="0" max="10"
                       class="form-control"
                       value="{{ recette.note ? recette.note.noteAspect : '' }}">
            </div>

            <div class="col-md-3 mb-3">
                <label>Odeur</label>
                <input type="number" name="noteOdeur"
                       min="0" max="10"
                       class="form-control"
                       value="{{ recette.note ? recette.note.noteOdeur : '' }}">
            </div>

            <div class="col-md-3 mb-3">
                <label>Goût</label>
                <input type="number" name="noteGout"
                       min="0" max="10"
                       class="form-control"
                       value="{{ recette.note ? recette.note.noteGout : '' }}">
            </div>

            <div class="col-md-3 mb-3">
                <label>Texture</label>
                <input type="number" name="noteTexture"
                       min="0" max="10"
                       class="form-control"
                       value="{{ recette.note ? recette.note.noteTexture : '' }}">
            </div>

        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success">
                💾 Enregistrer
            </button>
        </div>

    </form>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const categorieSelect = document.getElementById('categorie-select');
            const produitSelect = document.getElementById('produit-select');

            categorieSelect.addEventListener('change', function () {

                const categorieId = this.value;

                if (!categorieId) {
                    produitSelect.innerHTML = '<option value="">-- Choisir une catégorie --</option>';
                    return;
                }

                const urlTemplate = "{{ path('admin.produits_by_categorie', {'id': 'ID'}) }}";
                const url = urlTemplate.replace('ID', categorieId);

                produitSelect.innerHTML = '<option>Chargement...</option>';

                fetch(url)
                    .then(response => response.json())
                    .then(data => {

                        produitSelect.innerHTML = '';

                        data.forEach(produit => {
                            const option = document.createElement('option');
                            option.value = produit.id;
                            option.textContent = produit.nom;
                            produitSelect.appendChild(option);
                        });

                        if (data.length === 0) {
                            produitSelect.innerHTML = '<option>Aucun produit</option>';
                        }
                    })
                    .catch(() => {
                        produitSelect.innerHTML = '<option>Erreur de chargement</option>';
                    });

            });

        });
    </script>

{% endblock %}