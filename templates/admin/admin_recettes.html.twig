{% extends 'base.admin.html.twig' %}

{% block title %}Recettes{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1>🍽 Gestion des recettes</h1>

        <a href="{{ path('recette_add_page') }}" class="btn btn-primary">
            + Ajouter une recette
        </a>

    </div>

    <div class="admin-card">

        <table class="table align-middle">

            <thead>
                <tr>
                    <th class="sortable" data-sort="nom">Nom ⬍</th>
                    <th class="sortable" data-sort="duree">Durée ⬍</th>
                    <th>Catégories</th>
                    <th class="sortable" data-sort="note">Note ⬍</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>

                {% for recette in recettes %}

                    <tr data-nom="{{ recette.nom|lower }}"
                        data-duree="{{ recette.duree ?? 0 }}"
                        data-note="{{ recette.note ? recette.note.total : 0 }}">

                        <td>
                            <strong>{{ recette.nom }}</strong>
                        </td>

                        <td>
                            {% if recette.duree %}
                                ⏱ {{ recette.duree }} min
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if recette.categories is not empty %}
                                {% for cat in recette.categories %}
                                    <span class="badge bg-secondary">
                                        {{ cat.nom }}
                                    </span>
                                {% endfor %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if recette.note %}
                                <span class="badge bg-warning text-dark">
                                    ⭐ {{ recette.note.total }}/40
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>

                        <td class="text-end">

                            <a href="{{ path('recette_edit', {id: recette.id}) }}"
                               class="btn btn-sm btn-outline-primary">
                                ✏️ Modifier
                            </a>

                            <a href="{{ path('recette_manage', {id: recette.id}) }}"
                               class="btn btn-sm btn-outline-success">
                                ⚙️ Gérer
                            </a>

                            <form method="POST"
                                  action="{{ path('recette_delete', {id: recette.id}) }}"
                                  onsubmit="return confirm('Supprimer cette recette ?');"
                                  style="display:inline;">

                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger">
                                    🗑 Supprimer
                                </button>

                            </form>

                        </td>

                    </tr>

                {% else %}

                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Aucune recette trouvée
                        </td>
                    </tr>

                {% endfor %}

            </tbody>

        </table>

    </div>

{% endblock %}
{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            let direction = {};

            document.querySelectorAll('.sortable').forEach(header => {

                header.style.cursor = 'pointer';

                header.addEventListener('click', function () {

                    const key = this.dataset.sort;
                    const table = this.closest('table');
                    const tbody = table.querySelector('tbody');

                    const rows = Array.from(tbody.querySelectorAll('tr'));

                    direction[key] = !direction[key];

                    rows.sort((a, b) => {

                        let valA = a.dataset[key];
                        let valB = b.dataset[key];

                        if (key === 'nom') {
                            return direction[key]
                                    ? valA.localeCompare(valB)
                                    : valB.localeCompare(valA);
                        }

                        return direction[key]
                                ? valA - valB
                                : valB - valA;
                    });

                    rows.forEach(row => tbody.appendChild(row));

                });

            });

        });
    </script>

{% endblock %}